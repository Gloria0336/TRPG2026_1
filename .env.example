# ── Discord ─────────────────────────────────────────────
# Bot token from https://discord.com/developers/applications
DISCORD_TOKEN=your-discord-bot-token-here
# (optional) restrict the bot to a single guild for faster slash-command sync
DISCORD_GUILD_ID=
# Player portal Discord OAuth. Redirect URI should point at the FastAPI backend,
# for example: https://your-api.example.com/api/portal/auth/discord/callback
DISCORD_OAUTH_CLIENT_ID=
DISCORD_OAUTH_CLIENT_SECRET=
DISCORD_OAUTH_REDIRECT_URI=

# ── OpenRouter (https://openrouter.ai/keys) ─────────────
OPENROUTER_API_KEY=sk-or-your-key-here
# Layered routing (§8.2): cheap model parses intent, strong model narrates.
MODEL_INTENT=openai/gpt-4o-mini
MODEL_NARRATE=anthropic/claude-sonnet-4.5
# Sent as HTTP-Referer / X-Title for OpenRouter attribution (optional)
OPENROUTER_APP_URL=http://localhost:8000
OPENROUTER_APP_NAME=AI Living World MVP

# ── Web dashboard ───────────────────────────────────────
WEB_HOST=127.0.0.1
WEB_PORT=8000
# Comma-separated origins allowed to call API/SSE from the Vercel player portal.
# Keep blank for localhost-only dashboard use.
# Example: WEB_CORS_ORIGINS=https://your-project.vercel.app
WEB_CORS_ORIGINS=

# ── Player portal ───────────────────────────────────────
# Public URL of the Vercel-hosted portal. OAuth returns users here after login.
PORTAL_PUBLIC_URL=http://localhost:8000
# Set a long random value in production.
PORTAL_SESSION_SECRET=change-me-for-production
# For HTTPS production with cross-site Vercel -> API cookies, use:
# PORTAL_COOKIE_SECURE=1
# PORTAL_COOKIE_SAMESITE=none
PORTAL_COOKIE_SECURE=0
PORTAL_COOKIE_SAMESITE=lax

# ── Engine ──────────────────────────────────────────────
# Leave blank for real randomness; set an int for deterministic dice (debugging).
DICE_SEED=
# How many recent event_log entries to feed the narrator as context.
NARRATE_CONTEXT_WINDOW=12
# Set to 1 to run without calling the LLM (uses canned narration) — handy offline.
AI_OFFLINE=0
