# ── Discord ─────────────────────────────────────────────
# Bot token from https://discord.com/developers/applications
DISCORD_TOKEN=your-discord-bot-token-here
# (optional) restrict the bot to a single guild for faster slash-command sync
DISCORD_GUILD_ID=
# Player portal Discord OAuth. Redirect URI should point at the local public
# portal server, or to the Cloudflare Tunnel hostname that forwards to it.
# Local example: http://127.0.0.1:8001/api/portal/auth/discord/callback
DISCORD_OAUTH_CLIENT_ID=
DISCORD_OAUTH_CLIENT_SECRET=
DISCORD_OAUTH_REDIRECT_URI=

# ── OpenRouter (https://openrouter.ai/keys) ─────────────
OPENROUTER_API_KEY=sk-or-your-key-here
# Layered routing (§8.2): cheap model parses intent, strong model narrates.
MODEL_INTENT=openai/gpt-4o-mini
MODEL_NARRATE=anthropic/claude-sonnet-4.5
# Sent as HTTP-Referer / X-Title for OpenRouter attribution (optional)
OPENROUTER_APP_URL=http://localhost:8000
OPENROUTER_APP_NAME=AI Living World MVP

# ── Web dashboard ───────────────────────────────────────
WEB_HOST=127.0.0.1
WEB_PORT=8000
PORTAL_HOST=127.0.0.1
PORTAL_PORT=8001
# Comma-separated origins allowed to call API/SSE from a separate player portal
# origin. Keep blank when the portal and portal API are served from the same
# local public server / Cloudflare Tunnel hostname.
WEB_CORS_ORIGINS=

# ── Player portal ───────────────────────────────────────
# Public URL of the player portal. For local portal development use 8001.
# With Cloudflare Tunnel, replace this with the public HTTPS hostname.
PORTAL_PUBLIC_URL=http://127.0.0.1:8001
# Set a long random value in production.
PORTAL_SESSION_SECRET=change-me-for-production
# For HTTPS via Cloudflare Tunnel, use:
# PORTAL_COOKIE_SECURE=1
# PORTAL_COOKIE_SAMESITE=lax
PORTAL_COOKIE_SECURE=0
PORTAL_COOKIE_SAMESITE=lax

# ── Engine ──────────────────────────────────────────────
# Active scenario pack under app/content/scenarios/<name>/.
SCENARIO=dawnbridge
# Leave blank for real randomness; set an int for deterministic dice (debugging).
DICE_SEED=
# How many recent event_log entries to feed the narrator as context.
NARRATE_CONTEXT_WINDOW=12
# Set to 1 to run without calling the LLM (uses canned narration) — handy offline.
AI_OFFLINE=0
